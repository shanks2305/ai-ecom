generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
}

enum VerificationPurpose {
  BOOTSTRAP
  LOGIN
  REGISTER
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ConversationStage {
  BROWSING
  REGISTERING
  LOGGING_IN
  AUTHENTICATED
  ADMIN
}
enum ConversationChannel {
  WEB
  TELEGRAM
  WHATSAPP
  DISCORD
}
enum ConversationStatus {
  ACTIVE
  ARCHIVED
  CLOSED
}
enum MessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique @db.VarChar(255)
  firstName    String?   @db.VarChar(100)
  lastName     String?   @db.VarChar(100)
  role         Role      @default(CUSTOMER)
  isVerified   Boolean   @default(false)
  isActive     Boolean   @default(true)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  conversations Conversation[]
  sessions Session[]

  @@index([deletedAt])
  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique @db.Text
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Verification {
  id        String   @id @default(uuid())
  email     String   @unique @db.VarChar(255)
  codeHash  String   @db.VarChar(255)
  purpose   VerificationPurpose @default(LOGIN)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([expiresAt])
  @@map("verifications")
}

model Brand {
  id          String    @id @default(uuid())
  name        String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(255)
  description String?   @db.Text
  logo        String?   @db.Text
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products Product[]

  @@index([deletedAt])
  @@map("brands")
}

model Category {
  id          String     @id @default(uuid())
  name        String     @db.VarChar(255)
  slug        String     @unique @db.VarChar(255)
  description String?    @db.Text
  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    Category[] @relation("CategoryHierarchy")
  deletedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  products Product[]

  @@index([deletedAt])
  @@map("categories")
}

model Product {
  id          String        @id @default(uuid())
  name        String        @db.VarChar(255)
  slug        String        @unique @db.VarChar(255)
  description String?       @db.Text
  sku         String        @unique @db.VarChar(255)
  price       Float
  currency    String        @default("INR")
  status      ProductStatus @default(DRAFT)
  brandId     String
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  brand       Brand         @relation(fields: [brandId], references: [id], onDelete: Cascade)
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([brandId])
  @@index([categoryId])
  @@index([deletedAt])
  @@map("products")

  inventories Inventory[]
  images ProductImage[]
}

model Inventory {
  id               String    @id @default(uuid())
  productId        String
  product          Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity         Int
  reservedQuantity Int       @default(0)
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([productId])
  @@index([deletedAt])
  @@map("inventories")
}

model ProductImage {
  id        String    @id @default(uuid())
  productId String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String    @db.Text
  altText   String?   @db.VarChar(255)
  sortOrder Int       @default(0)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([productId])
  @@index([deletedAt])
  @@map("product_images")
}

model Conversation {
  id               String              @id @default(uuid())
  userId           String?
  user             User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  stage            ConversationStage   @default(BROWSING)
  channel          ConversationChannel @default(WEB)
  externalThreadId String?             @db.VarChar(255)
  title            String?             @db.VarChar(255)
  summary          String?             @db.Text
  metadata         Json?
  lastMessageAt    DateTime?
  status           ConversationStatus  @default(ACTIVE)
  deletedAt        DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  messages Message[]
  @@unique([channel, externalThreadId])
  @@index([userId])
  @@index([lastMessageAt])
  @@index([deletedAt])
  @@map("conversations")
}

model Message {
  id                String      @id @default(uuid())
  conversationId    String
  conversation      Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sequence          Int
  role              MessageRole
  content           String?     @db.Text
  toolCalls         Json?
  toolCallId        String?     @db.VarChar(255)
  toolName          String?     @db.VarChar(100)
  model             String?     @db.VarChar(100)
  promptTokens      Int?
  completionTokens  Int?
  finishReason      String?     @db.VarChar(50)
  createdAt         DateTime    @default(now())
  @@unique([conversationId, sequence])
  @@index([conversationId])
  @@map("messages")
}